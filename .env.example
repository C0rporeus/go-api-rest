# === Server ===
PORT=3100

# === Provider ===
# Controls which persistence backend is used for user data.
# Valid values: dynamodb
DB_PROVIDER=dynamodb

# === JWT ===
JWT_SECRET=change-me
JWT_EXPIRY_HOURS=24

# === AWS / DynamoDB ===
# Use AWS_PROFILE for local development with shared credentials (~/.aws/credentials)
# or set AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY in your environment.
# Do NOT commit real credentials to this file.
AWS_REGION=us-east-1
DYNAMO_DB_TABLE=users

# === Data ===
PORTFOLIO_DATA_DIR=./data

# === CORS ===
CORS_ALLOWED_ORIGINS=http://localhost:3000

# === Image upload (GCP Storage) ===
# Bucket where images are uploaded (e.g. Firebase Storage bucket). If unset, POST /api/private/upload-image returns 503.
# GCS_BUCKET_NAME=my-project.appspot.com
# Signed URL expiry for reading images (hours). Default: 168 (7 days).
# SIGNED_URL_EXPIRY_HOURS=168

# === Observability (optional) ===
# OPS_ALERT_MIN_REQUESTS=20
# OPS_WARN_5XX_RATE=0.05
# OPS_CRITICAL_5XX_RATE=0.10
# OPS_WARN_AUTH_FAIL_RATE=0.10
# OPS_CRITICAL_AUTH_FAIL_RATE=0.20
# OPS_WINDOW_SECONDS=300
# OPS_HEALTH_HISTORY_LIMIT=100
# OPS_SUMMARY_SAMPLE_SIZE=50
